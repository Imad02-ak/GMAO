st-observation"></textarea></div></div></form></div><div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button><button class="btn btn-warning" data-stock-action="save-ajustement">Enregistrer l'ajustement</button></div></div></div>
    </div>

    <div class="modal fade" id="modal-commande-achat" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Nouvelle commande d'achat</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><form id="form-commande-achat"><div class="row g-3"><div class="col-md-4"><label class="form-label">Fournisseur</label><div class="input-group"><span class="input-group-text"><i class="fa-solid fa-truck"></i></span><select class="form-select" id="cmd-fournisseur" required></select></div></div><div class="col-md-3"><label class="form-label">Date commande</label><div class="input-group"><span class="input-group-text"><i class="fa-solid fa-calendar"></i></span><input class="form-control" type="date" id="cmd-date" required></div></div><div class="col-md-3"><label class="form-label">Date livraison prévue</label><div class="input-group"><span class="input-group-text"><i class="fa-solid fa-calendar"></i></span><input class="form-control" type="date" id="cmd-date-livraison" required></div></div><div class="col-md-2"><label class="form-label">N° BC</label><div class="input-group"><span class="input-group-text"><i class="fa-solid fa-file-alt"></i></span><input class="form-control" id="cmd-numero"></div></div><div class="col-12"><label class="form-label">Observations</label><div class="input-group"><span class="input-group-text"><i class="fa-solid fa-comment"></i></span><textarea class="form-control" rows="2" id="cmd-observation"></textarea></div></div></div><hr><div class="d-flex justify-content-between align-items-center mb-2"><div class="fw-semibold">Lignes de commande</div><button class="btn btn-outline-primary btn-sm" type="button" data-stock-action="add-cmd-line">Ajouter une ligne</button></div><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Article</th><th>Qté commandée</th><th>Prix unit.</th><th>Total ligne</th><th></th></tr></thead><tbody id="cmd-lignes-body"></tbody><tfoot><tr><th colspan="3" class="text-end">Total commande</th><th><span id="cmd-total">0</span></th><th></th></tr></tfoot></table></div></form></div><div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button><button class="btn btn-outline-primary" data-stock-action="save-commande">Enregistrer brouillon</button><button class="btn btn-primary" data-stock-action="send-commande">Envoyer</button></div></div></div>
    </div>

    <div class="modal fade" id="modal-fournisseur-form" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-md modal-dialog-scrollable"><div class="modal-content"><div class="modal-header"><h5 class="modal-title" id="fournisseur-modal-title">Nouveau fournisseur</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><form id="form-fournisseur"><input type="hidden" id="fournisseur-id"><div class="mb-3"><label class="form-label">Code</label><div class="input-group"><span class="input-group-text"><i class="fa-solid fa-hashtag"></i></span><input class="form-control" id="fournisseur-code"></div></div><div class="mb-3"><label class="form-label">Nom de l'entreprise</label><div class="input-group"><span class="input-group-text"><i class="fa-solid fa-building"></i></span><input class="form-control" id="fournisseur-nom" required></div></div><div class="mb-3"><label class="form-label">Nom du contact</label><div class="input-group"><span class="input-group-text"><i class="fa-solid fa-user"></i></span><input class="form-control" id="fournisseur-contact" required></div></div><div class="mb-3"><label class="form-label">Téléphone</label><div class="input-group"><span class="input-group-text"><i class="fa-solid fa-phone"></i></span><input class="form-control" id="fournisseur-telephone"></div></div><div class="mb-3"><label class="form-label">Email</label><div class="input-group"><span class="input-group-text"><i class="fa-solid fa-envelope"></i></span><input class="form-control" type="email" id="fournisseur-email"></div></div><div class="mb-3"><label class="form-label">Adresse</label><div class="input-group"><span class="input-group-text"><i class="fa-solid fa-map-pin"></i></span><textarea class="form-control" rows="2" id="fournisseur-adresse"></textarea></div></div><div class="mb-3"><label class="form-label">Délai moyen de livraison (jours)</label><div class="input-group"><span class="input-group-text"><i class="fa-solid fa-shipping-fast"></i></span><input class="form-control" type="number" min="1" id="fournisseur-delai"></div></div><div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="fournisseur-actif" checked><label class="form-check-label" for="fournisseur-actif">Actif</label></div></form></div><div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button><button class="btn btn-primary" data-stock-action="save-fournisseur">Enregistrer</button></div></div></div>
    </div>

    <div class="modal fade" id="modal-fournisseur-detail" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Détail fournisseur</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body" id="fournisseur-detail-body"></div></div></div>
    </div>

    <div class="modal fade" id="modal-quick-create" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><span id="quick-create-title">Créer</span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3" id="quick-create-parent-row" style="display:none">
                        <span class="text-muted small" id="quick-create-parent-label"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="quick-create-code">Code</label>
                        <input type="text" class="form-control" id="quick-create-code" readonly autocomplete="off">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="quick-create-nom">Nom</label>
                        <input type="text" class="form-control" id="quick-create-nom" placeholder="Entrez le nom..." autocomplete="off">
                        <div class="invalid-feedback">Ce champ est requis.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" type="button" data-bs-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-primary" id="quickCreateConfirmBtn"><i class="fa-solid fa-check me-1"></i>Créer</button>
                </div>
            </div>
        </div>
    </div>

    <div id="bt-printable" class="bt-printable"></div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toast-container"></div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/algeria-geo.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
</body>
</html>
