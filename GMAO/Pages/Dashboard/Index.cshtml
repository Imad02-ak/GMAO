                            <div class="col-md-4 gmao-form-group">
                                <label class="form-label">N° OT</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                                    <input class="form-control" type="text" data-di-ot-field="numero" readonly>
                                </div>
                            </div>
                            <div class="col-md-8 gmao-form-group">
                                <label class="form-label gmao-required">Titre OT</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fa-solid fa-heading"></i></span>
                                    <input class="form-control" type="text" data-di-ot-field="titre" required>
                                </div>
                                <div class="invalid-feedback">Ce champ est requis.</div>
                            </div>
                            <div class="col-md-6 gmao-form-group">
                                <label class="form-label gmao-required">Type</label>
                                <select class="form-select" data-di-ot-field="typeMaintenance" required>
                                    <option value="">Sélectionner</option>
                                    <option value="MC-Corrective">MC-Corrective</option>
                                    <option value="MP-Préventive">MP-Préventive</option>
                                    <option value="MA-Améliorative">MA-Améliorative</option>
                                    <option value="MR-Réglementaire">MR-Réglementaire</option>
                                </select>
                                <div class="invalid-feedback">Ce champ est requis.</div>
                            </div>
                            <div class="col-md-6 gmao-form-group">
                                <label class="form-label gmao-required">Priorité</label>
                                <select class="form-select" data-di-ot-field="priorite" required>
                                    <option value="">Sélectionner</option>
                                    <option value="URGENTE">Urgente</option>
                                    <option value="HAUTE">Haute</option>
                                    <option value="NORMALE">Normale</option>
                                    <option value="BASSE">Basse</option>
                                </select>
                                <div class="invalid-feedback">Ce champ est requis.</div>
                            </div>
                            <div class="col-md-6 gmao-form-group">
                                <label class="form-label gmao-required">Date prévue début</label>
                                <input class="form-control" type="date" data-di-ot-field="dateDebut" required>
                                <div class="invalid-feedback">Ce champ est requis.</div>
                            </div>
                            <div class="col-md-6 gmao-form-group">
                                <label class="form-label gmao-required">Date prévue fin</label>
                                <input class="form-control" type="date" data-di-ot-field="dateFin" required>
                                <div class="invalid-feedback">Ce champ est requis.</div>
                            </div>
                            <div class="col-md-12 gmao-form-group">
                                <label class="form-label">Technicien</label>
                                <select class="form-select" data-di-ot-field="technicien"></select>
                            </div>
                        </div>
                        <div class="di-ot-info mt-3">ⓘ L'OT sera lié à cette DI. Vous pourrez compléter les détails depuis le module Ordres de Travail.</div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-success" data-di-action="create-ot">Créer l'Ordre de Travail</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modal-di-detail" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Détail Demande d'Intervention</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body" id="di-detail-body"></div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modal-ot-detail" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Détail Ordre de Travail</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body" id="ot-detail-body"></div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modal-bt-generate" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-sm modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Générer un Bon de Travail</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    <div class="bt-summary-card mb-3" data-bt-generate-summary></div>
                    <form id="form-bt-generate" class="needs-validation" novalidate>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label">N° BT</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                                <input class="form-control" type="text" data-bt-field="numero" readonly>
                            </div>
                        </div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label">Date prévue</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-calendar"></i></span>
                                <input class="form-control" type="date" data-bt-field="datePrevue" required>
                            </div>
                            <div class="invalid-feedback">Ce champ est requis.</div>
                        </div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label">Heure prévue</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-clock"></i></span>
                                <input class="form-control" type="time" data-bt-field="heurePrevue">
                            </div>
                        </div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label">Instructions spéciales</label>
                            <textarea class="form-control" rows="2" data-bt-field="instructionsSpeciales"></textarea>
                        </div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label">Consignes sécurité</label>
                            <textarea class="form-control" rows="2" data-bt-field="consignesSecurite"></textarea>
                        </div>
                        <div class="mb-2 text-uppercase text-muted fw-semibold">EPI requis</div>
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="Casque" id="epi-casque" data-bt-epi>
                                <label class="form-check-label" for="epi-casque">Casque</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="Gants" id="epi-gants" data-bt-epi>
                                <label class="form-check-label" for="epi-gants">Gants</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="Lunettes" id="epi-lunettes" data-bt-epi>
                                <label class="form-check-label" for="epi-lunettes">Lunettes</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="Chaussures sécu." id="epi-chaussures" data-bt-epi>
                                <label class="form-check-label" for="epi-chaussures">Chaussures sécu.</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="Harnais" id="epi-harnais" data-bt-epi>
                                <label class="form-check-label" for="epi-harnais">Harnais</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="Masque" id="epi-masque" data-bt-epi>
                                <label class="form-check-label" for="epi-masque">Masque</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" value="Combinaison" id="epi-combinaison" data-bt-epi>
                                <label class="form-check-label" for="epi-combinaison">Combinaison</label>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-primary" data-bt-action="generate-confirm">Générer le BT</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modal-bt-detail" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Détail Bon de Travail</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body" id="bt-detail-body"></div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modal-bt-validate" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-md modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Validation du Bon de Travail</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body" id="bt-validate-body"></div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-success" data-bt-action="validate-confirm">Confirmer</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modal-bt-print" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Bon de Travail imprimable</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body" id="bt-print-body"></div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
                    <button type="button" class="btn btn-outline-primary" data-bt-action="print-confirm"><i class="fa-solid fa-print me-2"></i>Imprimer</button>
                </div>
            </div>
        </div>
    </div>

    <div id="bt-printable" class="bt-printable"></div>

    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toast-container"></div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/algeria-geo.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
</body>
</html>
