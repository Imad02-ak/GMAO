                            <label class="form-label gmao-required">Département parent</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-th-large"></i></span>
                                <select class="form-select" data-field="departementId" data-parent-select="services" required></select>
                            </div>
                            <div class="invalid-feedback">Ce champ est requis.</div>
                        </div>

                        <div class="mb-3 text-uppercase text-muted fw-semibold">Identification</div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label">Code service</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                                <input class="form-control" type="text" data-field="code" readonly>
                            </div>
                        </div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label gmao-required">Nom du service</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-warehouse"></i></span>
                                <input class="form-control" type="text" data-field="nom" required>
                            </div>
                            <div class="invalid-feedback">Ce champ est requis.</div>
                        </div>

                        <div class="mb-3 text-uppercase text-muted fw-semibold">Localisation physique</div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label gmao-required">Wilaya</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-map-marker-alt"></i></span>
                                <select class="form-select" data-geo="wilaya" data-field="wilaya" required></select>
                            </div>
                            <div class="invalid-feedback">Ce champ est requis.</div>
                        </div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label gmao-required">Daïra</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-map"></i></span>
                                <select class="form-select" data-geo="daira" data-field="daira" required></select>
                            </div>
                            <div class="invalid-feedback">Ce champ est requis.</div>
                        </div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label gmao-required">Commune</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-location-arrow"></i></span>
                                <select class="form-select" data-geo="commune" data-field="commune" required></select>
                            </div>
                            <div class="invalid-feedback">Ce champ est requis.</div>
                        </div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label">Bâtiment / Hall</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-building"></i></span>
                                <input class="form-control" type="text" data-field="batiment">
                            </div>
                        </div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label">Adresse détaillée</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-map-pin"></i></span>
                                <input class="form-control" type="text" data-field="adresse">
                            </div>
                        </div>
                        <div class="location-inherited-info d-none" data-location-info="services"></div>

                        <div class="mb-3 text-uppercase text-muted fw-semibold">Contact &amp; Responsable</div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label gmao-required">Chef de service</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-user-tie"></i></span>
                                <input class="form-control" type="text" data-field="chef" required>
                            </div>
                            <div class="invalid-feedback">Ce champ est requis.</div>
                        </div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label gmao-required">Téléphone</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-phone"></i></span>
                                <input class="form-control" type="text" data-field="telephone" pattern="[0-9+\s-]+" required>
                            </div>
                            <div class="invalid-feedback">Veuillez saisir un numéro valide.</div>
                        </div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label gmao-required">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-envelope"></i></span>
                                <input class="form-control" type="email" data-field="email" required>
                            </div>
                            <div class="invalid-feedback">Veuillez saisir un email valide.</div>
                        </div>

                        <div class="mb-3 text-uppercase text-muted fw-semibold">Informations complémentaires</div>
                        <div class="mb-3 gmao-form-group">
                            <label class="form-label">Description</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-align-left"></i></span>
                                <textarea class="form-control" rows="3" data-field="description"></textarea>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="button" class="btn btn-primary" data-org-action="save" data-level="services">Enregistrer</button>
                </div>
            </div>
        </div>
    </div>

