@page
@model GMAO.Pages.Auth.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Connexion";
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GMAO Pro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-body">
    <div class="auth-card">
        <section class="auth-panel-left">
            <div>
                <div class="auth-logo">
                    <div class="logo-icon">
                        <i class="fa-solid fa-gear"></i>
                    </div>
                    <h1>GMAO PRO</h1>
                    <p>Gestion de Maintenance Assist�e par Ordinateur</p>
                </div>

                <div class="auth-feature">
                    <div class="auth-feature-icon">
                        <i class="fa-solid fa-tools"></i>
                    </div>
                    <div>
                        <h6>Gestion des �quipements</h6>
                        <p>Suivez et planifiez la maintenance de vos actifs</p>
                    </div>
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-icon">
                        <i class="fa-solid fa-clipboard-list"></i>
                    </div>
                    <div>
                        <h6>Gestion des interventions</h6>
                        <p>Cr�ez et assignez des t�ches en temps r�el</p>
                    </div>
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-icon">
                        <i class="fa-solid fa-chart-line"></i>
                    </div>
                    <div>
                        <h6>Tableaux de bord</h6>
                        <p>Analysez les performances de votre maintenance</p>
                    </div>
                </div>
            </div>
            <p class="auth-tagline">Optimisez votre maintenance, maximisez vos performances.</p>
        </section>

        <section class="auth-panel-right">
            <div class="auth-logo-mobile">
                <div class="logo-icon">
                    <i class="fa-solid fa-gear"></i>
                </div>
                <h1>GMAO Pro</h1>
                <p>Gestion de Maintenance Assist�e par Ordinateur</p>
            </div>
            <div class="mb-4">
                <h2 class="auth-panel-title">Connexion</h2>
                <p class="auth-panel-subtitle">Acc�dez � votre espace GMAO</p>
            </div>

            <form method="post" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label class="form-label" asp-for="Input.Email"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-envelope"></i></span>
                        <input asp-for="Input.Email" class="form-control" placeholder="Adresse e-mail" />
                    </div>
                    <span class="text-danger small" asp-validation-for="Input.Email"></span>
                </div>

                <div class="mb-2">
                    <label class="form-label" asp-for="Input.Password"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-lock"></i></span>
                        <input asp-for="Input.Password" class="form-control" placeholder="Mot de passe" />
                        <button type="button" class="btn btn-outline-secondary" id="togglePassword" aria-label="Afficher le mot de passe">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                    <span class="text-danger small" asp-validation-for="Input.Password"></span>
                </div>
                <div class="mb-3 text-end">
                    <a class="link-muted" asp-page="/Auth/ForgotPassword">Mot de passe oubli� ?</a>
                </div>

                <div class="mb-4">
                    <label class="form-label" asp-for="Input.CompanyCode"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="fa-solid fa-building"></i></span>
                        <input asp-for="Input.CompanyCode" class="form-control" placeholder="Code entreprise (ex: 4@gml)" />
                    </div>
                    <span class="text-danger small" asp-validation-for="Input.CompanyCode"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    <i class="fa-solid fa-right-to-bracket me-2"></i>Se connecter
                </button>

                <div class="text-center mt-3">
                    <span class="text-muted">Pas encore de compte ?</span>
                    <a class="link-muted" asp-page="/Auth/Register">S'inscrire</a>
                </div>
            </form>
        </section>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script>
        const togglePassword = document.getElementById("togglePassword");
        const passwordInput = document.getElementById("Input_Password");

        togglePassword?.addEventListener("click", () => {
            if (!passwordInput) {
                return;
            }

            const isPassword = passwordInput.getAttribute("type") === "password";
            passwordInput.setAttribute("type", isPassword ? "text" : "password");
            togglePassword.querySelector("i")?.classList.toggle("fa-eye");
            togglePassword.querySelector("i")?.classList.toggle("fa-eye-slash");
        });
    </script>
</body>
</html>
